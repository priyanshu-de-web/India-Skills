<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport"
          content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Recurring Calendar - Express + Mongoose</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .calendar-box {
            width: 1200px;
            margin: 0 auto;
        }

        .calendar-month {
            display: flex;
            justify-content: center;
            gap: 10px;
        }

        .calendar-month input {
            width: 4rem;
            margin-right: 1rem;
        }

        .calendar-wrapper {
            display: flex;
            flex-wrap: wrap;
            margin: 1rem 0;
            border: 1px solid #ddd;
        }

        .calendar-item {
            width: calc(100% / 7);
            border: inherit;
            padding: 1rem;
            min-height: 100px;
        }

        .calendar-item.otherMonth {
            color: rgba(0, 0, 0, .5);
            background: rgba(0, 0, 0, .1);
        }

        .task-item {
            background: #3b4cff;
            color: #fff;
            padding: .4rem;
            margin-top: .4rem;
            font-size: 0.85rem;
            border-radius: 3px;
        }

        .required::before {
            content: "*";
            color: red;
        }

        form {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            align-items: center;
        }

        label {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        button {
            padding: 8px 16px;
            cursor: pointer;
        }
    </style>
    <script>
        function selectRecurring(){
            const value = document.querySelector("[name='is_recurring']:checked").value;
            const recurringInfo = document.querySelector("#recurring_info");
            if(value === "true") {
                recurringInfo.innerHTML = `
                    <label>
                        <span class="required"></span>Cycle
                        <input type="number" name="cycle" min="1" required value="1">
                    </label>
                    <label>
                        <span class="required"></span>Type
                        <select name="type" required>
                            <option value="D" selected>Day</option>
                            <option value="W">Week</option>
                            <option value="M">Month</option>
                            <option value="Y">Year</option>
                        </select>
                    </label>
                    <label>
                        End date
                        <input type="date" name="end_date">
                    </label>
                `
            } else {
                recurringInfo.innerHTML = "";
            }
        }
    </script>
</head>
<body>
<div class="calendar-box">

    <form class="calendar-month" action="/" method="GET">
        <label>Year:
            <input type="number" value="<%= year %>" name="year" min="1">
        </label>
        <label>
            Month:
            <input type="number" value="<%= month %>" name="month" min="1" max="12">
        </label>
        <button type="submit">Change</button>
    </form>

    <div class="calendar-wrapper">
        <div class="calendar-item">S</div>
        <div class="calendar-item">M</div>
        <div class="calendar-item">T</div>
        <div class="calendar-item">W</div>
        <div class="calendar-item">T</div>
        <div class="calendar-item">F</div>
        <div class="calendar-item">S</div>

        <% for(let i = 0; i <= diffDays; i++) { %>
            <% const currentDate = addDays(startDate, i); %>
            <% const currentMonth = currentDate.getMonth() + 1; %>
            <div class="calendar-item <%= currentMonth !== month ? 'otherMonth' : '' %>">
                <%= currentDate.getDate() %>

                <div class="task-wrapper">
                    <% if(tasks[i]) { %>
                        <% tasks[i].forEach(function(task) { %>
                            <div class="task-item"><%= task.title %></div>
                        <% }); %>
                    <% } %>
                </div>
            </div>
        <% } %>
    </div>

    <form action="/tasks" method="POST">
        <label>
            <span class="required"></span>Title
            <input type="text" name="title" required>
        </label>

        <label>
            <span class="required"></span>Task date
            <input type="date" name="task_date" required>
        </label>

        <div>
            <label>
                One day task
                <input type="radio" name="is_recurring" value="false" onchange="selectRecurring()" checked>
            </label>
            <label>
                Recurring task
                <input type="radio" name="is_recurring" value="true" onchange="selectRecurring()">
            </label>
        </div>

        <div id="recurring_info">
        </div>

        <div>
            <button type="submit">Create</button>
        </div>
    </form>

</div>
</body>
</html>
